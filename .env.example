# --- IT Value Bridge environment (self-hosted, air-gapped) ---
# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Database: local Postgres from docker-compose.yml. Data stays on this host.
# Inside docker-compose (app service), use host `db` instead of `localhost`.
DATABASE_URL="postgresql://itvb:itvb@localhost:5432/itvb"

# Auth.js session secret. Generate your own:  openssl rand -base64 32
AUTH_SECRET="replace-with-output-of: openssl rand -base64 32"

# Air-gapped compliance: AI narrative OFF (no external API calls). Keep false for the bank build.
ENABLE_AI_NARRATIVE="false"
