# --- IT Value Bridge environment ---
# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# On-prem (Docker / real deployment): local Postgres, data stays on the host.
#   DATABASE_URL="postgresql://itvb:itvb@localhost:5432/itvb"
#   (inside docker-compose use host `db` instead of `localhost`)
#
# Hosted demo (Vercel + Neon): paste Neon's *pooled* connection string here and
# in the Vercel project's Environment Variables. It already includes sslmode.
#   DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/itvb?sslmode=require"
DATABASE_URL="postgresql://itvb:itvb@localhost:5432/itvb"

# ---------------------------------------------------------------------------
# AUTH
# ---------------------------------------------------------------------------
# Auth.js session secret. Generate your own:  openssl rand -base64 32
AUTH_SECRET="replace-with-output-of: openssl rand -base64 32"

# ---------------------------------------------------------------------------
# FLAGS
# ---------------------------------------------------------------------------
# Air-gapped compliance: AI narrative OFF (no external API calls). Keep false for the bank build.
ENABLE_AI_NARRATIVE="false"

# Shows a "Demo environment — sample data only" badge. Set to "true" ONLY on the
# hosted evaluation instance; leave unset/false for real on-prem deployments.
NEXT_PUBLIC_DEMO_MODE="false"

# Workspace identity shown in the sidebar. Set to the bank / pilot name.
# Example: "Bandhan Bank — IT Value Bridge Pilot"
NEXT_PUBLIC_WORKSPACE_NAME="IT Value Bridge Pilot Workspace"
