// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------
enum Role {
  ADMIN
  CIO
  PMO
  VERTICAL_HEAD
  BUSINESS
  PROGRAM_HEAD
  PROGRAM_MANAGER
  BUSINESS_HEAD
}

enum InitiativeType {
  CHANGE_REQUEST
  PROJECT
}

// Leadership importance, independent of delivery type (InitiativeType) and
// regulatory criticality (isRegulatory) — a regulatory initiative can be
// Strategic, Major Project, Tactical, or BAU.
enum InitiativeClassification {
  STRATEGIC
  MAJOR_PROJECT
  TACTICAL
  BAU
}

enum Methodology {
  WATERFALL
  AGILE
}

enum Stage {
  BRD
  FSD
  COMMERCIAL
  DEVELOPMENT
  SIT
  UAT
  APPSEC
  CAB_APPROVAL
  GO_LIVE
  BUSINESS_VALIDATION
  CLOSED
}

enum ProcessGroup {
  INITIATING
  PLANNING
  EXECUTING
  MONITORING_CONTROLLING
  CLOSING
}

enum BenefitCategory {
  REVENUE
  COST_SAVING
  CUSTOMER_EXPERIENCE
  COMPLIANCE
  EFFICIENCY
  RISK_REDUCTION
}

enum DelaySource {
  IT
  BUSINESS
  VENDOR
  EXTERNAL
}

enum KnowledgeAreaName {
  INTEGRATION
  SCOPE
  SCHEDULE
  COST
  QUALITY
  RESOURCE
  COMMUNICATIONS
  RISK
  PROCUREMENT
  STAKEHOLDER
}

enum KAStatus {
  GREEN
  AMBER
  RED
}

enum OutcomeAchieved {
  YES
  PARTIALLY
  NO
}

enum StoryStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

// ---------- Value realization ----------
enum BenefitUnit {
  INR
  PERCENT
  DAYS
  HOURS
  COUNT
  RATIO
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}

enum DemandStatus {
  RAISED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ON_HOLD
}

enum DemandPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ---------- Workspace / Organisation ----------
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  industry  String?
  status    String   @default("PILOT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  initiatives Initiative[]
  demands     Demand[]
  okrs        Okr[]
  reports     MonthlyReport[]
}

// ---------- Auth / Users ----------
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  // when role = VERTICAL_HEAD this is their own name key used to scope initiatives
  verticalHead String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Enterprise role model — which portfolio/reporting line this user belongs
  // to. Directory/reporting metadata: who this user's Program Head, Program
  // Manager, and Business Head are, and their business unit / sub-unit.
  // Nullable — most pilot users won't have these set.
  programHeadName    String?
  programManagerName String?
  businessHeadName   String?
  businessUnit       String?
  subBusinessUnit    String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  ownedInitiatives Initiative[] @relation("VerticalHeadInitiatives")
  historyEntries   HistoryLog[]
  raisedDemands    Demand[]     @relation("RaisedDemands")
}

// ---------- Core ----------
model Initiative {
  id             String                   @id @default(cuid())
  title          String
  type           InitiativeType
  classification InitiativeClassification @default(TACTICAL)
  methodology    Methodology              @default(WATERFALL)

  verticalHeadName String
  verticalHead     User?   @relation("VerticalHeadInitiatives", fields: [verticalHeadId], references: [id])
  verticalHeadId   String?
  businessSpoc     String
  businessSponsor  String
  description      String

  // Enterprise role model — assignment fields for manager-level visibility.
  // Nullable: existing initiatives predate these and pilot data may leave
  // them unset. Matched by name against the assignee's session, mirroring
  // how verticalHeadName/businessSpoc already scope VERTICAL_HEAD/BUSINESS.
  programHeadName    String?
  programManagerName String?
  businessHeadName   String?
  businessUnit       String?
  subBusinessUnit    String?

  // business value (intent) — benefitCategory/outcomeDescription/targetMetric
  // are the legacy single-benefit summary; structured value lives in BenefitClaim[].
  benefitCategory    BenefitCategory
  outcomeDescription String
  targetMetric       String
  expectedGoLiveDate DateTime

  // value governance / cost (Value Realization Layer)
  estimatedCostInr Float?
  actualCostInr    Float?
  valueSignedOff   Boolean   @default(false)
  valueSignOffBy   String?
  valueSignOffAt   DateTime?

  // regulatory / compliance criticality (e.g. RBI/NPCI-mandated, externally-fixed deadline)
  isRegulatory      Boolean   @default(false)
  regulatoryBody    String?
  regulatoryDueDate DateTime?

  // waterfall current-state (only meaningful when methodology = WATERFALL)
  currentStage        Stage        @default(BRD)
  currentProcessGroup ProcessGroup @default(INITIATING)
  stageStartDate      DateTime
  stageExpectedDate   DateTime
  lastUpdated         DateTime
  notes               String       @default("")
  delayed             Boolean      @default(false)
  delaySource         DelaySource?
  delayReason         String?

  committedMonth String? // "YYYY-MM" for monthly-commitment tracking

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages           WaterfallStage[]
  milestones       Milestone[]
  knowledgeAreas   KnowledgeArea[]
  risks            Risk[]
  stakeholders     Stakeholder[]
  valueRealization BusinessValueRealization?
  history          HistoryLog[]
  epics            Epic[]
  sprints          Sprint[]
  stories          Story[]
  benefitClaims    BenefitClaim[]
  okrLinks         InitiativeOkr[]
  originDemand     Demand?                   @relation("DemandInitiative")
  dependsOn        Dependency[]              @relation("Dependent")
  blocking         Dependency[]              @relation("Blocker")

  @@index([verticalHeadName])
  @@index([currentStage])
  @@index([type])
  @@index([classification])
  @@index([organizationId, classification])
  @@index([organizationId, isRegulatory])
  @@index([organizationId, businessUnit])
  @@index([organizationId, businessHeadName])
  @@index([organizationId, programHeadName])
  @@index([organizationId, programManagerName])
}

model WaterfallStage {
  id            String       @id @default(cuid())
  initiative    Initiative   @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId  String
  stage         Stage
  processGroup  ProcessGroup
  expectedDate  DateTime
  startedDate   DateTime?
  completedDate DateTime?
  daysInStage   Int? // snapshot only; live value computed at render
  delayFlag     Boolean      @default(false)
  delaySource   DelaySource?

  @@unique([initiativeId, stage])
  @@index([initiativeId])
}

// A flat list of named checkpoints per initiative — deliberately lightweight.
// Not a WBS: no parent/child hierarchy, no subtasks, no dependency links
// between milestones (that's Dependency, which is between Initiatives, not
// this), no Gantt/scheduling fields, no resource or effort/hours tracking,
// no sprint/task board linkage, no timesheets. If any of that is ever
// needed, it's a deliberate new model/feature, not an extension of this one.
//
// Typical checkpoints (not enforced — title is free text): BRD Sign-off,
// FSD Sign-off, SIT Completion, UAT Sign-off, AppSec Closure, CAB Approval,
// Go-Live Readiness, Business Validation.
model Milestone {
  id           String     @id @default(cuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  title       String // checkpoint name, e.g. "UAT Sign-off"
  description String? // optional detail
  owner       String // accountable person/team
  ownerRole   String? // reference values: PMO / IT / Business / Vendor — free text, not an enum
  dueDate     DateTime // planned checkpoint date
  status      MilestoneStatus @default(NOT_STARTED)

  completedAt DateTime? // actual completion date
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([initiativeId])
  @@index([status])
  @@index([dueDate])
}

// ---------- Governance (delivery health areas) ----------
model KnowledgeArea {
  id           String            @id @default(cuid())
  initiative   Initiative        @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId String
  name         KnowledgeAreaName
  status       KAStatus          @default(GREEN)
  notes        String            @default("")
  updatedAt    DateTime          @updatedAt

  @@unique([initiativeId, name])
}

model Risk {
  id           String     @id @default(cuid())
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId String
  description  String
  probability  Int // 1..5
  impact       Int // 1..5
  response     String
  owner        String
  createdAt    DateTime   @default(now())

  @@index([initiativeId])
}

model Stakeholder {
  id           String     @id @default(cuid())
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId String
  name         String
  role         String
  influence    Int // 1..5
  interest     Int // 1..5

  @@index([initiativeId])
}

model BusinessValueRealization {
  id              String          @id @default(cuid())
  initiative      Initiative      @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId    String          @unique
  outcomeAchieved OutcomeAchieved
  actualResult    String
  actualMetric    String
  realizedDate    DateTime?
  updatedAt       DateTime        @updatedAt
}

// ---------- Agile ----------
model Epic {
  id           String     @id @default(cuid())
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId String
  title        String
  description  String     @default("")
  stories      Story[]

  @@index([initiativeId])
}

model Sprint {
  id           String     @id @default(cuid())
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId String
  number       Int
  startDate    DateTime
  endDate      DateTime
  capacity     Int // story points
  stories      Story[]

  @@unique([initiativeId, number])
  @@index([initiativeId])
}

model Story {
  id           String      @id @default(cuid())
  initiative   Initiative  @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId String
  epic         Epic?       @relation(fields: [epicId], references: [id])
  epicId       String?
  sprint       Sprint?     @relation(fields: [sprintId], references: [id])
  sprintId     String?
  title        String
  points       Int         @default(0)
  status       StoryStatus @default(TODO)
  createdAt    DateTime    @default(now())

  @@index([initiativeId])
  @@index([sprintId])
}

// ---------- Cross-cutting ----------
model HistoryLog {
  id           String     @id @default(cuid())
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId String
  stage        Stage?
  note         String
  user         User?      @relation(fields: [userId], references: [id])
  userId       String?
  userName     String // denormalized for display stability
  createdAt    DateTime   @default(now())

  @@index([initiativeId])
}

model MonthlyReport {
  id          String   @id @default(cuid())
  month       Int // 1..12
  year        Int
  payload     Json // aggregated snapshot (completed/delayed/missed)
  narrative   String? // AI-generated narrative (nullable until generated)
  generatedAt DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([year, month])
}

// ---------- Value Realization Layer ----------

// A single quantified benefit claimed by an initiative or a demand.
// One initiative/demand can carry several (multi-benefit). RAG/value totals
// are computed at render; the ₹ figure (estimatedAnnualValueInr) is what rolls
// up into board dashboards once the parent initiative's value is signed off.
model BenefitClaim {
  id           String      @id @default(cuid())
  initiative   Initiative? @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId String?
  demand       Demand?     @relation(fields: [demandId], references: [id], onDelete: Cascade)
  demandId     String?

  category                 BenefitCategory
  metricName               String // e.g. "UPI transaction drop rate"
  baselineValue            Float?
  targetValue              Float?
  unit                     BenefitUnit     @default(INR)
  estimatedAnnualValueInr  Float           @default(0) // ₹ value for board rollups
  confidence               Confidence      @default(MEDIUM)
  realizationHorizonMonths Int             @default(12)
  narrative                String          @default("")

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  measurements ValueMeasurement[]

  @@index([initiativeId])
  @@index([demandId])
}

// A point-in-time reading of realized value for a benefit claim (+3/+6/+12mo).
model ValueMeasurement {
  id             String       @id @default(cuid())
  benefitClaim   BenefitClaim @relation(fields: [benefitClaimId], references: [id], onDelete: Cascade)
  benefitClaimId String
  measuredAt     DateTime     @default(now())
  horizonLabel   String // "+3m", "+6m", "+12m"
  actualValue    Float?
  realizedInr    Float?
  note           String       @default("")
  recordedByName String?

  @@index([benefitClaimId])
}

// Bank strategic metric / OKR catalog. Initiatives map to one or more.
model Okr {
  id              String           @id @default(cuid())
  name            String
  description     String           @default("")
  category        BenefitCategory?
  owner           String           @default("")
  targetStatement String           @default("")
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  links InitiativeOkr[]
}

model InitiativeOkr {
  id               String     @id @default(cuid())
  initiative       Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  initiativeId     String
  okr              Okr        @relation(fields: [okrId], references: [id], onDelete: Cascade)
  okrId            String
  contributionNote String     @default("")

  @@unique([initiativeId, okrId])
  @@index([initiativeId])
  @@index([okrId])
}

// Demand-management funnel: business raises a need with quantified benefit(s),
// PMO triages, and on approval it converts into an Initiative.
model Demand {
  id               String         @id @default(cuid())
  title            String
  requirement      String
  raisedBy         User?          @relation("RaisedDemands", fields: [raisedById], references: [id])
  raisedById       String?
  raisedByName     String
  verticalHeadName String?
  status           DemandStatus   @default(RAISED)
  priority         DemandPriority @default(MEDIUM)
  reviewNote       String         @default("")

  convertedInitiative   Initiative? @relation("DemandInitiative", fields: [convertedInitiativeId], references: [id])
  convertedInitiativeId String?     @unique

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  benefitClaims BenefitClaim[]

  @@index([status])
}

// ---------- Cross-system dependencies ----------
// "dependent depends on blocker" (i.e. blocker blocks dependent). Optional
// systemLabel names the shared system/interface (e.g. "CBS Loans API").
model Dependency {
  id          String     @id @default(cuid())
  dependent   Initiative @relation("Dependent", fields: [dependentId], references: [id], onDelete: Cascade)
  dependentId String
  blocker     Initiative @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockerId   String
  systemLabel String?
  note        String     @default("")
  createdAt   DateTime   @default(now())

  @@unique([dependentId, blockerId])
  @@index([dependentId])
  @@index([blockerId])
}
